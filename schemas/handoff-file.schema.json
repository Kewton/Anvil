{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/handoff-file.schema.json",
  "title": "Anvil Handoff File",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "formatVersion",
    "createdBy",
    "source",
    "sessionId",
    "objective",
    "workingSummary",
    "activePlanSummary",
    "latestEvidenceSummary",
    "pendingSteps",
    "relevantFiles",
    "pmModel",
    "agentModels",
    "permissionMode",
    "networkPolicy"
  ],
  "properties": {
    "formatVersion": {
      "type": "string",
      "const": "2"
    },
    "createdBy": {
      "type": "string",
      "maxLength": 100
    },
    "source": {
      "type": "string",
      "enum": ["anvil-session-export", "anvil-task-snapshot"]
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "maxLength": 131072
    },
    "workingSummary": {
      "type": "string",
      "maxLength": 131072
    },
    "activePlanSummary": {
      "type": "string",
      "maxLength": 131072
    },
    "latestEvidenceSummary": {
      "type": "string",
      "maxLength": 131072
    },
    "repositorySummary": {
      "type": "string",
      "maxLength": 131072
    },
    "pendingSteps": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 300 }
    },
    "completedSteps": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 300 }
    },
    "activeConstraints": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 300 }
    },
    "openQuestions": {
      "type": "array",
      "maxItems": 10,
      "items": { "type": "string", "maxLength": 300 }
    },
    "relevantFiles": {
      "type": "array",
      "maxItems": 200,
      "items": { "type": "string", "maxLength": 400 }
    },
    "recentFindings": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "recentResults": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/resultRecord"
      }
    },
    "pmModel": {
      "type": "string"
    },
    "permissionMode": {
      "type": "string",
      "enum": ["read-only", "workspace-write", "full-access"]
    },
    "networkPolicy": {
      "type": "string",
      "enum": ["local-only", "disabled", "enabled-with-approval"]
    },
    "agentModels": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reader": { "type": ["string", "null"] },
        "editor": { "type": ["string", "null"] },
        "tester": { "type": ["string", "null"] },
        "reviewer": { "type": ["string", "null"] }
      }
    },
    "exportedAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "$defs": {
    "evidenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType", "value"],
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": ["runtime-policy", "user", "anvil-md", "memory", "handoff", "repo-file", "tool-output"]
        },
        "value": {
          "type": "string",
          "maxLength": 400
        }
      }
    },
    "factRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "value"],
      "properties": {
        "key": {
          "type": "string",
          "maxLength": 100
        },
        "value": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "message"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "message": {
          "type": "string",
          "maxLength": 500
        },
        "file": {
          "type": "string",
          "maxLength": 400
        }
      }
    },
    "resultRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "model",
        "summary"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["reader", "editor", "tester", "reviewer"]
        },
        "model": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "maxLength": 131072
        },
        "facts": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/factRecord"
          }
        },
        "evidence": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/evidenceRecord"
          }
        },
        "changedFiles": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "maxLength": 400 }
        },
        "commandsRun": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "maxLength": 500 }
        },
        "nextRecommendation": {
          "type": "string",
          "maxLength": 500
        }
      }
    }
  }
}
