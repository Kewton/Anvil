{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/session-state.schema.json",
  "title": "Anvil Session State",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sessionId",
    "pmModel",
    "agentModels",
    "permissionMode",
    "networkPolicy",
    "objective",
    "workingSummary",
    "activePlanSummary",
    "latestEvidenceSummary",
    "userPreferencesSummary",
    "repositorySummary",
    "activeConstraints",
    "openQuestions",
    "completedSteps",
    "pendingSteps",
    "relevantFiles",
    "recentDelegations",
    "recentResults"
  ],
  "properties": {
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "pmModel": {
      "type": "string",
      "minLength": 1,
      "description": "Default model for the session and inheritance source for subagents."
    },
    "permissionMode": {
      "type": "string",
      "enum": ["read-only", "workspace-write", "full-access"],
      "description": "Effective base permission mode for the session."
    },
    "networkPolicy": {
      "type": "string",
      "enum": ["local-only", "disabled", "enabled-with-approval"],
      "description": "Network policy for the session."
    },
    "agentModels": {
      "type": "object",
      "description": "Per-agent model overrides. Null means inherit pmModel.",
      "additionalProperties": false,
      "properties": {
        "reader": { "type": ["string", "null"] },
        "editor": { "type": ["string", "null"] },
        "tester": { "type": ["string", "null"] },
        "reviewer": { "type": ["string", "null"] }
      }
    },
    "objective": {
      "type": "string",
      "maxLength": 131072
    },
    "workingSummary": {
      "type": "string",
      "maxLength": 131072
    },
    "activePlanSummary": {
      "type": "string",
      "maxLength": 131072
    },
    "latestEvidenceSummary": {
      "type": "string",
      "maxLength": 131072
    },
    "userPreferencesSummary": {
      "type": "string",
      "maxLength": 131072
    },
    "repositorySummary": {
      "type": "string",
      "maxLength": 131072
    },
    "activeConstraints": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 300 }
    },
    "openQuestions": {
      "type": "array",
      "maxItems": 10,
      "items": { "type": "string", "maxLength": 300 }
    },
    "completedSteps": {
      "type": "array",
      "maxItems": 50,
      "items": { "type": "string", "maxLength": 300 }
    },
    "pendingSteps": {
      "type": "array",
      "maxItems": 20,
      "items": { "type": "string", "maxLength": 300 }
    },
    "relevantFiles": {
      "type": "array",
      "maxItems": 200,
      "items": { "type": "string", "maxLength": 400 }
    },
    "recentDelegations": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/delegationRecord"
      }
    },
    "recentResults": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "$ref": "#/$defs/resultRecord"
      }
    },
    "pendingConfirmation": {
      "$ref": "#/$defs/pendingConfirmation"
    }
  },
  "$defs": {
    "delegationRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "resolvedModel",
        "inheritedFromPm",
        "task",
        "createdAt"
      ],
      "properties": {
        "id": { "type": "string" },
        "role": {
          "type": "string",
          "enum": ["reader", "editor", "tester", "reviewer"]
        },
        "resolvedModel": { "type": "string" },
        "inheritedFromPm": { "type": "boolean" },
        "task": { "type": "string", "maxLength": 131072 },
        "requestedPermission": {
          "type": "string",
          "enum": ["read-only", "workspace-write", "full-access"]
        },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "evidenceRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceType", "value"],
      "properties": {
        "sourceType": {
          "type": "string",
          "enum": ["runtime-policy", "user", "anvil-md", "memory", "handoff", "repo-file", "tool-output"]
        },
        "value": {
          "type": "string",
          "maxLength": 400
        }
      }
    },
    "factRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "value"],
      "properties": {
        "key": {
          "type": "string",
          "maxLength": 100
        },
        "value": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["severity", "message"],
      "properties": {
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "message": {
          "type": "string",
          "maxLength": 500
        },
        "file": {
          "type": "string",
          "maxLength": 400
        }
      }
    },
    "resultRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "model",
        "summary"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["reader", "editor", "tester", "reviewer"]
        },
        "model": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "maxLength": 131072
        },
        "facts": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/factRecord"
          }
        },
        "evidence": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/evidenceRecord"
          }
        },
        "changedFiles": {
          "type": "array",
          "maxItems": 50,
          "items": { "type": "string", "maxLength": 400 }
        },
        "commandsRun": {
          "type": "array",
          "maxItems": 20,
          "items": { "type": "string", "maxLength": 500 }
        },
        "nextRecommendation": {
          "type": "string",
          "maxLength": 500
        },
        "findings": {
          "type": "array",
          "maxItems": 20,
          "items": {
            "$ref": "#/$defs/finding"
          }
        }
      }
    },
    "pendingConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "task", "summary", "reason", "action"],
      "properties": {
        "role": {
          "type": "string",
          "enum": ["reader", "editor", "tester", "reviewer"]
        },
        "task": {
          "type": "string",
          "maxLength": 131072
        },
        "summary": {
          "type": "string",
          "maxLength": 131072
        },
        "reason": {
          "type": "string",
          "maxLength": 300
        },
        "action": {
          "$ref": "#/$defs/pendingAction"
        }
      }
    },
    "pendingAction": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "program", "args", "cwd", "display"],
          "properties": {
            "kind": {
              "type": "string",
              "const": "exec"
            },
            "program": {
              "type": "string",
              "minLength": 1
            },
            "args": {
              "type": "array",
              "maxItems": 20,
              "items": { "type": "string", "maxLength": 300 }
            },
            "cwd": {
              "type": "string",
              "minLength": 1
            },
            "display": {
              "type": "string",
              "minLength": 1,
              "maxLength": 500
            }
          }
        }
      ]
    }
  }
}
