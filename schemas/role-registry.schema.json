{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://anvil.dev/schemas/role-registry.schema.json",
  "title": "Anvil Role Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "formatVersion",
    "defaultSessionRole",
    "roles"
  ],
  "properties": {
    "formatVersion": {
      "type": "string",
      "const": "1"
    },
    "defaultSessionRole": {
      "type": "string",
      "description": "Primary coordinating role for the session."
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/roleDefinition"
      }
    }
  },
  "$defs": {
    "capability": {
      "type": "string",
      "enum": [
        "user-interaction",
        "repository-inspection",
        "planning",
        "file-edit",
        "command-execution",
        "review",
        "state-management"
      ]
    },
    "permissionLevel": {
      "type": "string",
      "enum": ["read-only", "workspace-write", "full-access"]
    },
    "roleDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "displayName",
        "description",
        "enabledInMvp",
        "userFacing",
        "supportsModelOverride",
        "defaultPermission",
        "capabilities"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "maxLength": 300
        },
        "enabledInMvp": {
          "type": "boolean"
        },
        "userFacing": {
          "type": "boolean"
        },
        "supportsModelOverride": {
          "type": "boolean"
        },
        "defaultPermission": {
          "$ref": "#/$defs/permissionLevel"
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/capability"
          }
        }
      }
    }
  }
}
